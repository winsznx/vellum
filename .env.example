# Sepolia deployer key (test wallet only — never a mainnet key with real funds)
TEST_PRIVATE_KEY=your_sepolia_test_private_key
TEST_WALLET_ADDRESS=0xYourTestWalletAddress
# RPC (publicnode default works; a dedicated Alchemy/Infura/QuickNode URL is more reliable)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Etherscan V2 API key (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key
